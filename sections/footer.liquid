{{ 'component-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign trust_badges = section.blocks | where: 'type', 'trust_badge'
  assign nav_columns = section.blocks | where: 'type', 'link_list'
  assign ig_handle = settings.social_instagram_link | replace: 'https://www.instagram.com/', '' | replace: 'http://www.instagram.com/', '' | replace: 'https://instagram.com/', '' | replace: 'http://instagram.com/', '' | remove: '/'
-%}

<footer class="footer color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="footer__main page-width">
    {%- if trust_badges.size > 0 -%}
      <div class="footer__trust-badges">
        {%- for block in trust_badges -%}
          <div class="footer__trust-badge" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <p class="footer__trust-badge-heading">{{ block.settings.heading | escape }}</p>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="footer__trust-badge-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <hr class="footer__divider footer__divider--trust-badges">
    {%- endif -%}

    <div class="footer__columns">
      <div class="footer__brand">
        <p class="footer__brand-name">{{ shop.name }}</p>
        {%- if section.settings.brand_tagline != blank -%}
          <p class="footer__brand-tagline">{{ section.settings.brand_tagline | escape }}</p>
        {%- endif -%}
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="footer__instagram">
            <span class="footer__instagram-icon">{{ 'icon-instagram.svg' | inline_asset_content }}</span>
            <span>@{{ ig_handle }}</span>
          </a>
        {%- endif -%}
      </div>

      {%- for block in nav_columns -%}
        <div class="footer__nav-column" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p class="footer__nav-heading">{{ block.settings.heading | escape }}</p>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="footer__nav-list list-unstyled">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="footer__nav-link link">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <hr class="footer__divider footer__divider--bottom">

    <div class="footer__bottom">
      {%- if section.settings.payment_enable -%}
        <ul class="footer__payment-icons list-unstyled" role="list">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          {%- for type in shop.enabled_payment_types -%}
            <li class="footer__payment-icon">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      <small class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}</small>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Réassurance",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Packaging signature"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Chaque bijou est présenté dans son écrin Diva by Diane."
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Colonne de liens",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Boutique"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Accroche de marque",
      "default": "BE A DIVA"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 32
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "trust_badge",
        "settings": { "heading": "Packaging signature", "text": "Chaque bijou est présenté dans son écrin Diva by Diane." }
      },
      {
        "type": "trust_badge",
        "settings": { "heading": "Livraison Colissimo", "text": "Offerte dès 50€ d'achat." }
      },
      {
        "type": "trust_badge",
        "settings": { "heading": "Retour sous 14 jours", "text": "Frais de retour à la charge de la cliente." }
      },
      {
        "type": "link_list",
        "settings": { "heading": "Boutique", "menu": "main-menu" }
      },
      {
        "type": "link_list",
        "settings": { "heading": "Aide", "menu": "footer" }
      },
      {
        "type": "link_list",
        "settings": { "heading": "Légal", "menu": "footer" }
      }
    ]
  }
}
{% endschema %}
