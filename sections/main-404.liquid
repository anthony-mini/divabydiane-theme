{{ 'component-404.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign button_url = section.settings.button_link
  if button_url == blank
    assign button_url = routes.all_products_collection_url
  endif
-%}

<div class="error-404 color-{{ section.settings.color_scheme }}">
  <div class="error-404__content page-width">
    {%- if section.settings.heading != blank -%}
      <h1 class="error-404__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="error-404__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ button_url }}" class="error-404__button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "404",
  "class": "section-main-404",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "404"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texte d'explication",
      "default": "Cette page n'existe pas ou n'est plus disponible."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Découvrir nos bijoux"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton (par défaut : tous les produits)"
    }
  ]
}
{% endschema %}
